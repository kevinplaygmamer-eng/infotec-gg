PORT=5000
DATABASE_PATH=./meubanco.db

# Credenciais do Mercado Pago
# Coloque aqui o Access Token privado da sua aplicacao.
MERCADO_PAGO_ACCESS_TOKEN=TEST-0000000000000000-000000-00000000000000000000000000000000-000000000

# Chave publica usada apenas no frontend para renderizar o Brick de cartao.
MERCADO_PAGO_PUBLIC_KEY=TEST-00000000-0000-0000-0000-000000000000

# URL publica raiz do seu site. O sistema adiciona /api/webhooks/mercado-pago automaticamente.
PUBLIC_BASE_URL=https://sua-loja.onrender.com

# Opcional, mas recomendado: assinatura secreta gerada em Mercado Pago Developers > Webhooks.
MERCADO_PAGO_WEBHOOK_SECRET=
